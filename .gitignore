# ====================================
# Archivos temporales del sistema
# ====================================
.DS_Store
Thumbs.db

# ====================================
# Dependencias
# ====================================
/node_modules
/vendor

# ====================================
# Archivos y directorios públicos generados
# ====================================
/public/hot
/public/storage
/public/js
/public/css
/public/vendors
/public/mix-manifest.json
# Mantener solo si es necesario:
# !public/data
# !public/fonts
# !public/images

# ====================================
# Laravel - caché, logs y claves
# ====================================
/storage/*.key
/storage/app/*
/storage/framework/*
/storage/logs/*
!storage/app/public

# ====================================
# Archivos de entorno y credenciales
# ====================================
.env
.env.*.local
.env.local
.env.production
.env.staging
.env.prod
.env.org.prod
.env.info.prod
.env.backup

# ====================================
# Archivos de configuración locales
# ====================================
.idea
.vscode
*.sublime-project
*.sublime-workspace
/vuexy-shell-scripts

# ====================================
# Archivos temporales de PHP y Laravel
# ====================================
.phpunit.result.cache
Homestead.yaml
Homestead.json

# ====================================
# Archivos de lock frontend (si no se desean versionar)
# ====================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# ====================================
# Archivos de log
# ====================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
supervisord.log
supervisord.pid
error.log
error_log
access.log

# ====================================
# Archivos generados por OpenSSL u otros procesos
# ====================================
.rnd

# ====================================
# Otros
# ====================================
composer.lock

# ====================================
# Archivos de pruebas locales
# ====================================
/dev_scripts/
/docs/
_backup_old_estructure/